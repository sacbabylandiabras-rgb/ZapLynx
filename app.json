{
  "expo": {
    "name": "ZapLynx",
    "slug": "zaplynx-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0814"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.zaplynx.app",
      "buildNumber": "2",
      "infoPlist": {
        "UIBackgroundModes": ["remote-notification"]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a0814"
      },
      "package": "com.zaplynx.app"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "sounds": [
            "./assets/sounds/venda_aprovada.mp3",
            "./assets/sounds/venda_pendente.mp3",
            "./assets/sounds/venda_recusada.mp3",
            "./assets/sounds/saque_aprovado.mp3",
            "./assets/sounds/relatorio.mp3"
          ]
        }
      ]
    ],
    "scheme": "zaplynx",
    "backgroundColor": "#0a0814"
  }
}
